{
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
      "address": {
        "type": "object",
        "properties": {
          "street_address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        },
        "required": [
          "street_address",
          "city",
          "state"
        ]
      },
      "user": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "mail": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "mail"
        ]
      }
    },
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "addressOrUsers": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/definitions/address"
            },
            {
              "$ref": "#/definitions/user"
            }
          ]
        }
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/addressOrUsers"
      }
    ]
  }
}
