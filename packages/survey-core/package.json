{
  "name": "survey-core",
  "version": "2.5.22",
  "scripts": {
    "build": "rollup -c rollup.config.mjs --environment emitMinified,emitNonSourceFiles",
    "build:i18n": "rollup -c rollup.i18n.config.mjs --environment emitMinified",
    "build:themes": "rollup -c rollup.themes.config.mjs --environment emitMinified",
    "build:icons": "rollup -c rollup.icons.config.mjs --environment emitMinified",
    "watch:dev": "rollup -c rollup.config.mjs -w",
    "build:all": "npm run build && npm run build:i18n && npm run build:themes && npm run build:icons",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "test": "vitest run",
    "test:watch": "vitest --no-isolate",
    "test:postcss": "postcss build/survey-core.css --silent  -u postcss-calc -u autoprefixer -u postcss-fail-on-warn -u postcss-import -o survey-core.postcss.css && rimraf survey-core.postcss.css",
    "doc_gen": "node doc_generator/lib_docgenerator.js ./entries/chunks/model.ts",
    "doc_update": "chmod +x ./docupdate_npm.sh && ./docupdate_npm.sh",
    "release": "commit-and-tag-version --message \"Release: %s [azurepipelines skip]\" "
  },
  "main": "survey.core.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/surveyjs.git"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rollup/plugin-virtual": "^3.0.2",
    "@types/node": "18.11.12",
    "@types/signature_pad": "^2.3.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "autoprefixer": "^10.4.17",
    "commit-and-tag-version": "^11.0.0",
    "concurrently": "^5.2.0",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.1",
    "merge-files": "^0.1.2",
    "nano-css": "^5.6.2",
    "peggy": "^5.0.6",
    "postcss": "8.4.31",
    "postcss-calc": "9.0.1",
    "postcss-cli": "10.1.0",
    "postcss-fail-on-warn": "0.2.1",
    "postcss-import": "16.1.0",
    "rimraf": "2.5.4",
    "rollup": "^4.34.8",
    "rollup-plugin-svgo": "^2.0.0",
    "sass": "^1.62.1",
    "signature_pad": "^4.1.5",
    "surveyjs-doc-generator": "git+https://github.com/surveyjs/surveyjs-doc-generator.git",
    "ts-node": "3.3.0",
    "ts-pegjs": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "ts-pegjs": {
      "peggy": "^5.0.6"
    }
  },
  "commit-and-tag-version": {
    "bumpFiles": [
      "package.json"
    ]
  }
}