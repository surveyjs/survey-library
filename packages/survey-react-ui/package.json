{
    "name": "survey-react-ui",
    "version": "2.5.13",
    "files": [
        "**/*"
    ],
    "main": "survey-react-ui.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/surveyjs/surveyjs.git"
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs --environment emitMinified,emitNonSourceFiles",
        "watch:dev": "rollup -c -w",
        "start": "http-server . -o -c-1",
        "lint": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --fix",
        "test": "rollup -c rollup.tests.config.mjs && karma start ./karma.conf.js --single-run",
        "test:watch": "node ./test-watch.mjs",
        "accessibility-tests": "cross-env env=react playwright test --project a11y --ui",
        "accessibility-tests:ci": "cross-env env=react playwright test --project a11y --reporter dot --quiet",
        "e2e": "cross-env env=react playwright test --project e2e --ui",
        "e2e:ci": "cross-env env=react playwright test --project e2e",
        "scr": "cross-env env=react playwright test --project vrt --ui",
        "scr:ci": "cross-env env=react playwright test --project vrt",
        "release": "commit-and-tag-version --message \"Release: %s [azurepipelines skip]\" "
    },
    "typings": "./typings/src/entries/react-ui.d.ts",
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.0",
        "@types/node": "7.0.4",
        "@types/qunit": "2.0.31",
        "@types/react": "^17.0.83",
        "@types/react-dom": "^17.0.1",
        "@types/react-test-renderer": "^17.0.1",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "commit-and-tag-version": "^11.0.0",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.33.0",
        "http-server": "^14.1.1",
        "karma": "^6.1.1",
        "karma-chrome-launcher": "^3.1.0",
        "karma-junit-reporter": "2.0.1",
        "karma-qunit": "4.1.2",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "react-test-renderer": "^17.0.1",
        "rimraf": "2.5.4",
        "rollup": "^4.34.8",
        "survey-core": "../survey-core/build",
        "typescript": "^5.7.0"
    },
    "commit-and-tag-version": {
        "bumpFiles": [
            "package.json"
        ]
    }
}